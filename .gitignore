# Ignore everything
*

# But not these files...
!.gitignore
!*.py
!*.md
!requirements.txt

# ...and not these directories...
!cogs/
!cogs/**
!utils/
!utils/**

# Keep db/sumar directory but ignore its contents
!db/
!db/sumar/
db/sumar/*
!db/sumar/.gitkeep

# Keep log directory but ignore its contents
!log/
!log/.gitkeep
log/*
!log/.gitkeep

# Ignore sensitive files
.env
config.json
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
