# Discord Bot Configuration
# Get your Discord bot token from: https://discord.com/developers/applications
# IMPORTANT: Enable these intents in the Bot section:
# - Presence Intent (for presence updates)
# - Server Members Intent (for member events)
# - Message Content Intent (for message content)
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_server_id_here
WELCOME_CHANNEL_ID=your_welcome_channel_id_here

# Bot Activity Configuration
ACTIVITY_BASE_TEXT=Sleduji
ACTIVITY_FORMAT_TEXT={count} darebáků

# YouTube Configuration
# Get YouTube API key from: https://console.developers.google.com/
# API to use: YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=@your_youtube_channel_handle_here
YOUTUBE_NOTIFICATION_CHANNEL_ID=your_notification_channel_id_here
CHECK_INTERVAL_SECONDS=30

# Counting Game Configuration
# Set the channel ID where counting will happen
COUNTING_CHANNEL_ID=your_counting_channel_id_here
COUNTING_SAVE_FILE=db/counting.json
COUNTING_TOPIC_PREFIX=Počítejte od 1 do nekonečna. Další číslo:

# Update Checker Configuration
# Set the channel ID where update notifications will be sent
UPDATE_CHECK_CHANNEL_ID=your_update_channel_id_here
UPDATE_CHECK_INTERVAL_HOURS=1
CURRENT_VERSION=0.1

# AI Moderation Configuration
# Google Gemini API key for AI moderation
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# AI model to use for moderation
AI_MODEL=gemini-2.0-flash
# Number of messages to analyze per user
# This must be set to a value greater than 0
AI_MESSAGES_BATCH=15
# Database file for AI moderation
AI_MODERATION_SAVE_FILE=db/ai_moderation.json
# Interval in minutes to process message batches
AI_MODERATION_INTERVAL_MINUTES=5
# Positive score thresholds for role rewards
AI_POSITIVE_THRESHOLD_1=800
AI_POSITIVE_THRESHOLD_2=2000
AI_POSITIVE_THRESHOLD_3=5000
# Negative score thresholds
AI_NEGATIVE_THRESHOLD=-30
AI_VERY_NEGATIVE_THRESHOLD=-1000
# Penalty for very negative messages
AI_NEGATIVE_PENALTY=-50
# Role IDs for different levels
# Level 1 positive role (800+ points)
AI_POSITIVE_ROLE_ID_1=your_positive_role_id_level1_here
# Level 2 positive role (2000+ points)
AI_POSITIVE_ROLE_ID_2=your_positive_role_id_level2_here
# Level 3 positive role (5000+ points)
AI_POSITIVE_ROLE_ID_3=your_positive_role_id_level3_here
# Negative role (-1000 points)
AI_NEGATIVE_ROLE_ID=your_negative_role_id_here

# Audit Log Configuration
# Set the channel ID where audit logs will be sent
AUDIT_LOG_CHANNEL_ID=your_audit_log_channel_id_here

# Chat Summary Configuration
# OpenRouter API key for chat summarization
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OpenRouter model to use for summarization
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
# Chat ID to monitor for summarization (0 = all chats)
SUMMARY_CHAT_ID=your_chat_id_to_monitor_here
# Channel ID where summaries will be sent
SUMMARY_CHANNEL_ID=your_summary_channel_id_here

# Logger Configuration
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
# Maximum size of log files in bytes before rotation (5MB default)
LOG_MAX_SIZE=5242880
# Number of backup log files to keep
LOG_BACKUP_COUNT=10
