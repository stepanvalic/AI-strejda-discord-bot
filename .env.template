# API Keys and Tokens (Sensitive Information)
# This file should never be committed to version control
# Rename this file to .env and fill in your API keys

# Discord Bot Token
# Get your Discord bot token from: https://discord.com/developers/applications
# IMPORTANT: Enable these intents in the Bot section:
# - Presence Intent (for presence updates)
# - Server Members Intent (for member events)
# - Message Content Intent (for message content)
DISCORD_TOKEN=your_discord_token_here

# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API Key (via OpenRouter)
# For chat summarization
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
